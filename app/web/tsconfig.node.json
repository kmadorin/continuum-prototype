{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "skipLibCheck": true,

    /* Bundler mode. The config + the sandbox spine import the backend's TS sources
       (custody/, ledger-client/), which are written for bundler resolution — so is Vite's
       own config loader. nodenext here would demand .js extensions the sources don't use. */
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  /* The sandbox test runs under vitest globals, not this project. */
  "include": ["vite.config.ts", "sandbox/**/*.ts"],
  "exclude": ["sandbox/**/*.test.ts"]
}
