module Continuum.Credential where

-- Reusable, revocable eligibility attestation (e.g. Qualified Purchaser).
-- Not consumed by a deal, so a returning buyer reuses it across deals #1/#2.
template EligibilityCredential
  with
    issuer : Party
    holder : Party
    scheme : Text
    valid  : Bool
  where
    signatory issuer
    observer holder
    choice Revoke : ContractId EligibilityCredential
      controller issuer
      do create this with valid = False
